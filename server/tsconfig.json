{
  "compilerOptions": {
    "typeRoots": [
      "./src/types", // Path to your custom types folder
      "./node_modules/@types" // Default location for installed types
    ],
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "../admin/app/api"],
  "exclude": ["node_modules", "dist"]
}
